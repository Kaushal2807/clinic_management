const toothData = {
  ur: new Set(),
  ul: new Set(),
  lr: new Set(),
  ll: new Set()
};

document.querySelectorAll('.tooth').forEach(t => {
  t.addEventListener('click', () => {
    const q = t.dataset.q;
    const n = t.dataset.tooth;

    t.classList.toggle('active');

    toothData[q].has(n)
      ? toothData[q].delete(n)
      : toothData[q].add(n);

    document.getElementById(q).value =
      [...toothData[q]].join(',');
  });
});


$('#treatmentPlanModal2').on('shown.bs.modal', function () {

    $('.select-diagnosis').select2({
        dropdownParent: $('#treatmentPlanModal2'),
        width: '100%',
        placeholder: 'Search diagnosis'
    });

    $('.select-treatment').select2({
        dropdownParent: $('#treatmentPlanModal2'),
        width: '100%',
        placeholder: 'Search treatment'
    });

});





document.getElementById("treatmentPatientForm").addEventListener("submit", function (e) {
    e.preventDefault();

    const form = this;
    const formData = new FormData(form);

    fetch("save_patient_treatment.php", {
        method: "POST",
        body: formData
    })
    .then(res => res.text())
    .then(data => {
        console.log("SERVER:", data);

        if (data.trim() === "success") {

            Swal.fire({
                icon: "success",
                title: "Saved!",
                text: "Treatment saved successfully",
                timer: 1500,
                showConfirmButton: false
            });

            // Close modal
            const modal = bootstrap.Modal.getInstance(
                document.getElementById("treatmentPlanModal2")
            );
            modal.hide();

            // Reset form
            form.reset();

            // Clear selected teeth UI
            document.querySelectorAll('.tooth.active')
                .forEach(t => t.classList.remove('active'));

            // Clear hidden tooth inputs
            ['ur','ul','lr','ll'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.value = '';
            });

        } else {
            Swal.fire({
                icon: "error",
                title: "Error",
                text: data || "Failed to save treatment"
            });
        }
    })
    .catch(err => {
        console.error(err);
        Swal.fire({
            icon: "error",
            title: "AJAX Error",
            text: "Something went wrong"
        });
    });
});





// GENERATE CERTIFICATE 


function setCertificatePatient(uid, name) {
    document.getElementById("cert_patient_uid").value = uid;
    document.getElementById("cert_patient_name").value = name;

    document.getElementById("show_cert_patient_uid").value = uid;
    document.getElementById("show_cert_patient_name").value = name;
}



document.getElementById("certificateForm").addEventListener("submit", function (e) {
    e.preventDefault();

    const form = this;
    const formData = new FormData(form);

    fetch("save_certificate.php", {
        method: "POST",
        body: formData
    })
    .then(res => res.json())   // ✅ now JSON is valid
    .then(resp => {

        if (resp.status === "success") {

            Swal.fire({
                icon: "success",
                title: "Certificate Generated",
                timer: 1000,
                showConfirmButton: false
            });
            // 🔥 CLOSE MODAL FIRST
    const modalEl = document.getElementById("certificateModal");
    const modal = bootstrap.Modal.getInstance(modalEl);
    if (modal) modal.hide();
            // 🔥 OPEN PDF (NOT AJAX)
            window.location.href =
                "generate_certificate_pdf.php?id=" + resp.certificate_id;

        } else {
            Swal.fire("Error", resp.message || "Failed", "error");
        }
    })
    .catch(err => {
        console.error(err);
        Swal.fire("Error", "AJAX failed", "error");
    });
});

const certModal = document.getElementById('certificateModal');

certModal.addEventListener('show.bs.modal', function () {

    // Reset full form (clears textarea values)
    document.getElementById('certificateForm').reset();

    // Clear visible fields
    document.getElementById('show_cert_patient_uid').value = '';
    document.getElementById('show_cert_patient_name').value = '';

    // Clear hidden fields
    document.getElementById('cert_patient_uid').value = '';
    document.getElementById('cert_patient_name').value = '';
});


</script>




</body>
</html>
