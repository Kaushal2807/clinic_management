function loadPatientData(patient_uid) {

    fetch("get_patient.php?patient_uid=" + patient_uid)
    .then(r => r.json())
    .then(data => {

        document.getElementById("update_uid").value = data.patient_uid;
        document.getElementById("update_patient_uid").value = data.patient_uid;
        document.getElementById("update_name").value = data.name;
        document.getElementById("update_age").value = data.age;
        document.getElementById("update_contact").value = data.contact_number;
        document.getElementById("update_address").value = data.address;
        document.getElementById("update_date").value = data.date_of_visit;
        document.getElementById("update_notes").value = data.notes;
        document.getElementById("update_xray").value = data.xray_remark;
        document.getElementById("update_chief").value = data.chief_complain;
        document.getElementById("update_medical").value = data.medical_history;
        document.getElementById("update_oral").value = data.oral_diet_habit;
        document.getElementById("update_family").value = data.family_history;
        document.getElementById("update_visit").value = data.total_visit;
        document.getElementById("update_total_amount").value = data.total_amount;
        document.getElementById("update_paystatus").value = data.payment_status;
        document.getElementById("update_pending").value = data.payment_pending;

    });
}

