function filterPatients() {
    let input = document.getElementById("patientSearch").value.toLowerCase();
    let rows = document.querySelectorAll("table tbody tr");

    rows.forEach(row => {
        let pid = row.children[0].innerText.toLowerCase(); // patient ID
        let pname = row.children[1].innerText.toLowerCase(); // patient name

        if (pid.includes(input) || pname.includes(input)) {
            row.style.display = "";
        } else {
            row.style.display = "none";
        }
    });
}

function searchPatients() {
    const input = document.getElementById("patientSearch").value.toLowerCase();
    const rows = document.querySelectorAll("#patientTableBody tr");

    // If input is empty → restore original table (20 rows)
    if (input.trim() === "") {

        rows.forEach((row, index) => {
            if (row.dataset.extra === "1") {
                row.classList.add("d-none");   // hide extra rows
            } else {
                row.classList.remove("d-none"); // show original rows
            }
        });

        return;
    }

    // Searching → show matching rows only
    rows.forEach(row => {
        const pid = row.children[0].innerText.toLowerCase();
        const name = row.children[1].innerText.toLowerCase();

        if (pid.includes(input) || name.includes(input)) {
            row.classList.remove("d-none");
        } else {
            row.classList.add("d-none");
        }
    });
}




