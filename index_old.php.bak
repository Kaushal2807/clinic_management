
<?php
include "db_con.php";

/* DRUG */
$drugOptions = "";
$q = mysqli_query($conn, "SELECT id, drug_name FROM drug_master");
while ($row = mysqli_fetch_assoc($q)) {
    $drugOptions .= "<option value='{$row['id']}'>{$row['drug_name']}</option>";
}

/* DOSE */
$doseOptions = "";
$q = mysqli_query($conn, "SELECT id, dose_name FROM dose_master");
while ($row = mysqli_fetch_assoc($q)) {
    $doseOptions .= "<option value='{$row['id']}'>{$row['dose_name']}</option>";
}

/* FORM */
$formOptions = "";
$q = mysqli_query($conn, "SELECT id, form_name FROM drug_form_master");
while ($row = mysqli_fetch_assoc($q)) {
    $formOptions .= "<option value='{$row['id']}'>{$row['form_name']}</option>";
}

/* DURATION */
$durationOptions = "";
$q = mysqli_query($conn, "SELECT id, duration_name FROM duration_master");
while ($row = mysqli_fetch_assoc($q)) {
    $durationOptions .= "<option value='{$row['id']}'>{$row['duration_name']}</option>";
}

/* QUANTITY */
$quantityOptions = "";
$q = mysqli_query($conn, "SELECT id, quantity_name FROM drug_quantity_master");
while ($row = mysqli_fetch_assoc($q)) {
    $quantityOptions .= "<option value='{$row['id']}'>{$row['quantity_name']}</option>";
}

/* SUGGESTION */
$suggestOptions = "";
$q = mysqli_query($conn, "SELECT id, suggestion_name FROM drug_suggestion_master");
while ($row = mysqli_fetch_assoc($q)) {
    $suggestOptions .= "<option value='{$row['id']}'>{$row['suggestion_name']}</option>";
}
?>


