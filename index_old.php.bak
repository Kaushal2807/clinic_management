 <script>

  function loadNextPatientId() {
    fetch("get_last_patient_id.php")
    .then(response => response.text())
    .then(lastId => {

        // safety check
        if (!lastId || !lastId.includes("-")) {
            lastId = "PT-100";
        }

        const [prefix, num] = lastId.split("-");
        let nextNum = parseInt(num);

        // if num invalid → fallback
        if (isNaN(nextNum)) nextNum = 100;

        nextNum++;

        const newId = `${prefix}-${nextNum}`;

        document.getElementById("autoPatientId").value = newId;
    })
    .catch(() => {
        // if PHP file fails → fallback safe ID
        document.getElementById("autoPatientId").value = "PT-101";
    });
}





document.getElementById("addPatientForm").addEventListener("submit", function(e) {
    e.preventDefault(); // prevent page reload

    let formData = new FormData(this);

    fetch("add_patient.php", {
        method: "POST",
        body: formData
    })
    .then(res => res.text())
    .then(data => {
      console.log("SERVER RESPONSE: ", data);
        if (data.trim() === "success") {

            Swal.fire({
                icon: "success",
                title: "Patient Saved!",
                text: "Record added successfully.",
                timer: 1500,
                showConfirmButton: false
            });

            // Close modal
            let modalEl = document.getElementById("addPatientModal");
            let modal = bootstrap.Modal.getInstance(modalEl);
            modal.hide();

            // Reset form
            document.getElementById("addPatientForm").reset();
              // 🔥 Reload page AFTER the alert finishes
    setTimeout(() => {
        location.reload();
    }, 1500);

        } else {
            Swal.fire({
                icon: "error",
                title: "Failed!",
                text: "Something went wrong. Try again."
            });
        }
    });
});




