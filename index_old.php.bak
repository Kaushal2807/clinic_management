function addPrescriptionRow() {

    let row = `
    <tr>

      <!-- Drug (SEARCHABLE) -->
      <td>
        <select name="drug_id[]" class="form-select drug-select" required>
          <option value="">Select Drug</option>
          <?= $drugOptions ?>
        </select>
      </td>

      <td>
        <select name="dose_id[]" class="form-select" required>
          <option value="">Dose</option>
          <?= $doseOptions ?>
        </select>
      </td>

      <td>
        <select name="form_id[]" class="form-select" required>
          <option value="">Form</option>
          <?= $formOptions ?>
        </select>
      </td>

      <td>
        <select name="duration_id[]" class="form-select" required>
          <option value="">Duration</option>
          <?= $durationOptions ?>
        </select>
      </td>

      <td>
        <select name="quantity_id[]" class="form-select" required>
          <option value="">No</option>
          <?= $quantityOptions ?>
        </select>
      </td>

      <td>
        <input type="number" name="days[]" class="form-control form-control-sm"
               min="1" required>
      </td>

      <td>
        <select name="suggestion_id[]" class="form-select" required>
          <option value="">Suggest</option>
          <?= $suggestOptions ?>
        </select>
      </td>

      <td>
        <input type="text" name="total[]" class="form-control form-control-sm" required>
      </td>

      <td>
        <button type="button" class="btn btn-danger btn-sm"
                onclick="this.closest('tr').remove()">✖</button>
      </td>

    </tr>
    `;

    document.getElementById("prescriptionTableBody")
            .insertAdjacentHTML("beforeend", row);

    // 🔥 Initialize Select2 for newly added row
    $('.drug-select').select2({
        dropdownParent: $('#prescriptionModal'),
        width: '100%',
        placeholder: "Search drug"
    });
}






