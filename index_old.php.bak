let saveMode = "save"; // default

// Save & Print button click
// SAVE & PRINT
document.getElementById("saveAndPrintBtn").addEventListener("click", function () {
    document.getElementById("save_mode").value = "print";
    submitPrescription();
});

// NORMAL SAVE (form submit)
document.getElementById("prescriptionForm").addEventListener("submit", function(e) {
    e.preventDefault();
    document.getElementById("save_mode").value = "save";
    submitPrescription();
});




   function submitPrescription() {

    if (document.querySelectorAll("#prescriptionTableBody tr").length === 0) {
        Swal.fire("Error", "Please add at least one drug", "error");
        return;
    }

    let form = document.getElementById("prescriptionForm");
    let formData = new FormData(form);

    fetch("save_prescription.php", {
        method: "POST",
        body: formData
    })
    .then(res => res.json())
    .then(resp => {

        console.log("SERVER RESPONSE:", resp); // 🔴 keep for debug

        if (resp.status === "success") {

            Swal.fire({
                icon: "success",
                title: "Saved",
                timer: 1000,
                showConfirmButton: false
            });

            // 🔥 PRINT ONLY WHEN REQUIRED
            if (formData.get("save_mode") === "print") {

                // MUST be direct open (browser-safe)
                window.location.href =
                    "print_prescription.php?id=" + resp.prescription_id;
            }

            bootstrap.Modal
              .getInstance(document.getElementById("prescriptionModal"))
              .hide();

            form.reset();

        } else {
            Swal.fire("Error", resp.message, "error");
        }
    })
    .catch(err => {
        Swal.fire("Error", "AJAX failed", "error");
        console.error(err);
    });
}



